{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile Java to target/classes",
      "type": "shell",
      "command": "javac",
      "args": [
        "-encoding",
        "UTF-8",
        "-d",
        "target/classes",
        "src/main/java/com/eclinic/*.java"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    },
    {
      "label": "Run App from target/classes",
      "type": "shell",
      "command": "java",
      "args": [
        "-cp",
        "target/classes",
        "com.eclinic.App"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
